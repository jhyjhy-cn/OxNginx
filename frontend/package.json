    "monaco-editor": "^0.52.0",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.8",
