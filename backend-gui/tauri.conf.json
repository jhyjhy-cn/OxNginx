{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "OxNginx",
  "version": "1.1.0",
  "identifier": "cn.jhyjhy.oxnginx",
  "build": {
    "frontendDist": "ui",
    "devUrl": "http://localhost:9000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OxNginx",
        "width": 400,
        "height": 300,
        "minWidth": 400,
        "minHeight": 300,
        "center": true,
        "decorations": true,
        "resizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "bundle/server": "server",
      "bundle/backup": "backup",
      "bundle/ssl": "ssl",
      "bundle/wwwlogs": "wwwlogs",
      "bundle/wwwroot": "wwwroot"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"],
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
