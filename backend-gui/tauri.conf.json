{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "OxNginx",
  "version": "1.0.0",
  "identifier": "cn.jhyjhy.oxnginx",
  "build": {
    "frontendDist": "ui",
    "devUrl": "http://localhost:9000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OxNginx",
        "width": 550,
        "height": 600,
        "minWidth": 550,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "bundle/server": "server",
      "bundle/backup": "backup",
      "bundle/ssl": "ssl",
      "bundle/wwwlogs": "wwwlogs",
      "bundle/wwwroot": "wwwroot"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"],
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jhyjhy-cn/OxNginx/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1RTA2Qzk2M0I5NkQ0NDQKUldSRTFKWTdsbXpnRmRzRVNjQkRQVmhhMjBEd1BMY3RMTU5ub0F5TnM4VitsOUt1S1Y1TVMzVlAK"
    }
  }
}





